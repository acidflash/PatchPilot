POSTGRES_DB=patchpilot
POSTGRES_USER=patchpilot
POSTGRES_PASSWORD=change-me
APP_SECRET=change-me-long-random
PUBLIC_AGENT_URL=https://patch.axnet.ax

# Cloudflare Tunnel token from Cloudflare Zero Trust
CLOUDFLARED_TOKEN=replace-me

# Optional Discord alerts
DISCORD_WEBHOOK_URL=

# If true, agents self-update automatically when backend serves a newer agent.
# Safer default is false. Manual update is available from MGMT UI via action self_update.
PATCHPILOT_AUTO_AGENT_UPDATE=false

# Template approval model:
# false = new agents enroll as pending and must be approved in admin UI
# true  = old behavior, new agents become approved immediately
PATCHPILOT_AUTO_APPROVE_AGENTS=false
