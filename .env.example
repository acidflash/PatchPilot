POSTGRES_DB=patchpilot
POSTGRES_USER=patchpilot
POSTGRES_PASSWORD=change-me

# Secret used for CSRF token signing. Must be a long random string.
APP_SECRET=change-me-long-random

# The public URL agents use to reach the server (no trailing slash).
PUBLIC_AGENT_URL=https://patch.example.com

# Hostname that agents connect to. Requests to this host are restricted to
# agent API endpoints only (/api/v1/agent/*, /install.sh, /healthz).
AGENT_PUBLIC_HOSTNAME=patch.example.com

# Comma-separated hostnames for the admin dashboard. Requests to these hosts
# block agent endpoints and expose only /admin/*.
ADMIN_INTERNAL_HOSTNAMES=patch-admin.example.com,localhost,127.0.0.1

# Password for the admin dashboard (HTTP Basic Auth).
# Leave empty to disable authentication (not recommended for production).
ADMIN_PASSWORD=change-me

# Cloudflare Tunnel token from Cloudflare Zero Trust
CLOUDFLARED_TOKEN=replace-me

# Caddy reverse proxy
# Admin UI hostname — the hostname you browse to for the admin dashboard.
CADDY_ADMIN_HOSTNAME=patch-admin.example.com
# Contact email for TLS certificate registration.
CADDY_EMAIL=admin@example.com
# ACME CA directory URL. Remove or leave empty to use Let's Encrypt.
CADDY_ACME_CA=
# Optional: internal hostname for on-LAN agents so their real LAN IPs are recorded.
# Must match AGENT_INTERNAL_HOSTNAME. Comment out the block in Caddyfile if unused.
CADDY_AGENT_HOSTNAME=patch-agent.example.com

# Optional Discord alerts
DISCORD_WEBHOOK_URL=

# If true, agents self-update automatically when backend serves a newer agent.
# Safer default is false. Manual update is available from MGMT UI via action self_update.
PATCHPILOT_AUTO_AGENT_UPDATE=false

# Template approval model:
# false = new agents enroll as pending and must be approved in admin UI
# true  = old behavior, new agents become approved immediately
PATCHPILOT_AUTO_APPROVE_AGENTS=false
